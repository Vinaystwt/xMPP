{
  "name": "xmpp",
  "private": true,
  "type": "module",
  "version": "0.1.0",
  "description": "xMPP: the ultimate x402 ↔ MPP brain for autonomous agents on Stellar.",
  "license": "MIT",
  "homepage": "https://github.com/Vinaystwt/xMPP#readme",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Vinaystwt/xMPP.git"
  },
  "bugs": {
    "url": "https://github.com/Vinaystwt/xMPP/issues"
  },
  "packageManager": "pnpm@10.33.0",
  "engines": {
    "node": ">=22.18.0",
    "pnpm": ">=10.33.0"
  },
  "scripts": {
    "build": "turbo run build",
    "dev": "turbo run dev --parallel",
    "lint": "turbo run lint",
    "typecheck": "turbo run typecheck",
    "test": "turbo run test",
    "check": "pnpm lint && pnpm typecheck && pnpm test",
    "xmpp:gateway": "pnpm --filter @xmpp/gateway dev",
    "xmpp:facilitator": "pnpm --filter @xmpp/facilitator dev",
    "xmpp:mcp": "pnpm --filter @xmpp/mcp dev",
    "xmpp:dashboard": "pnpm --filter @xmpp/dashboard dev",
    "xmpp:services": "pnpm --filter @xmpp/demo-services dev",
    "xmpp:smoke": "pnpm exec tsx scripts/live-smoke.ts",
    "xmpp:smoke:fee-sponsored": "pnpm exec tsx scripts/fee-sponsored-smoke.ts",
    "xmpp:contracts:seed": "pnpm exec tsx contracts/scripts/seed-testnet.ts",
    "xmpp:bootstrap": "pnpm exec tsx scripts/bootstrap-testnet.ts",
    "xmpp:smart-account:bootstrap": "pnpm exec tsx scripts/bootstrap-smart-account.ts",
    "xmpp:smart-account:check": "pnpm exec tsx scripts/bootstrap-smart-account.ts --check",
    "xmpp:judge:preflight": "pnpm exec tsx scripts/judge-preflight.ts",
    "xmpp:demo": "pnpm exec tsx scripts/demo-stack.ts",
    "xmpp:demo:smoke": "pnpm exec tsx scripts/demo-stack.ts --smoke",
    "xmpp:test": "pnpm check",
    "release:pack": "pnpm build && pnpm exec tsx scripts/pack-public-packages.ts",
    "release:check": "pnpm check && pnpm release:pack"
  },
  "devDependencies": {
    "@stellar/stellar-sdk": "^15.0.1",
    "@eslint/js": "^10.0.1",
    "@types/node": "^24.5.2",
    "eslint": "^10.1.0",
    "prettier": "^3.8.1",
    "smart-account-kit-bindings": "0.1.2",
    "tsx": "^4.21.0",
    "turbo": "^2.8.12",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.57.2",
    "vitest": "^4.1.2"
  }
}
