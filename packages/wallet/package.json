{
  "name": "@xmpp/wallet",
  "version": "0.1.1",
  "description": "Advanced wallet and receipt-signing package for xMPP execution on Stellar.",
  "type": "module",
  "license": "MIT",
  "main": "dist/wallet/src/index.js",
  "types": "dist/wallet/src/index.d.ts",
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "sideEffects": false,
  "homepage": "https://github.com/Vinaystwt/xMPP#readme",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Vinaystwt/xMPP.git",
    "directory": "packages/wallet"
  },
  "bugs": {
    "url": "https://github.com/Vinaystwt/xMPP/issues"
  },
  "keywords": ["xmpp", "wallet", "stellar", "receipts", "agents", "smart-account"],
  "exports": {
    ".": {
      "types": "./dist/wallet/src/index.d.ts",
      "import": "./dist/wallet/src/index.js",
      "default": "./dist/wallet/src/index.js"
    }
  },
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "dev": "tsc -p tsconfig.json --watch",
    "lint": "eslint src",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "test": "vitest run src --passWithNoTests"
  },
  "dependencies": {
    "@stellar/stellar-sdk": "^14.6.1",
    "@xmpp/config": "workspace:*",
    "@xmpp/types": "workspace:*",
    "smart-account-kit": "0.2.10"
  }
}
