{
  "name": "@xmpp/logger",
  "version": "0.1.1",
  "description": "Structured logging package used across xMPP services, gateways, and SDK modules.",
  "type": "module",
  "license": "MIT",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "files": ["dist", "README.md", "LICENSE"],
  "sideEffects": false,
  "homepage": "https://github.com/Vinaystwt/xMPP#readme",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Vinaystwt/xMPP.git",
    "directory": "packages/logger"
  },
  "bugs": {
    "url": "https://github.com/Vinaystwt/xMPP/issues"
  },
  "keywords": ["xmpp", "logger", "stellar", "agents", "services"],
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "default": "./dist/index.js"
    }
  },
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "dev": "tsc -p tsconfig.json --watch",
    "lint": "eslint src",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "test": "vitest run --passWithNoTests"
  },
  "dependencies": {
    "pino": "^10.3.1"
  }
}
