{
  "name": "@xmpp/contract-runtime",
  "version": "0.1.1",
  "description": "Advanced Soroban contract client package for xMPP policy and session registry flows on Stellar.",
  "type": "module",
  "license": "MIT",
  "main": "dist/contract-runtime/src/index.js",
  "types": "dist/contract-runtime/src/index.d.ts",
  "files": ["dist", "README.md", "LICENSE"],
  "sideEffects": false,
  "homepage": "https://github.com/Vinaystwt/xMPP#readme",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Vinaystwt/xMPP.git",
    "directory": "packages/contract-runtime"
  },
  "bugs": {
    "url": "https://github.com/Vinaystwt/xMPP/issues"
  },
  "keywords": ["xmpp", "stellar", "soroban", "contracts", "policy", "sessions", "agents"],
  "exports": {
    ".": {
      "types": "./dist/contract-runtime/src/index.d.ts",
      "import": "./dist/contract-runtime/src/index.js",
      "default": "./dist/contract-runtime/src/index.js"
    }
  },
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "dev": "tsc -p tsconfig.json --watch",
    "lint": "eslint src",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "test": "vitest run --passWithNoTests"
  },
  "dependencies": {
    "@stellar/stellar-sdk": "^15.0.1",
    "@xmpp/config": "workspace:*",
    "@xmpp/logger": "workspace:*",
    "@xmpp/types": "workspace:*"
  }
}
