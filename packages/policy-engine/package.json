{
  "name": "@xmpp/policy-engine",
  "version": "0.1.1",
  "description": "Advanced xMPP policy evaluation package for service, agent, treasury, and contract-aware decisions.",
  "type": "module",
  "license": "MIT",
  "main": "dist/policy-engine/src/index.js",
  "types": "dist/policy-engine/src/index.d.ts",
  "files": ["dist", "README.md", "LICENSE"],
  "sideEffects": false,
  "homepage": "https://github.com/Vinaystwt/xMPP#readme",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Vinaystwt/xMPP.git",
    "directory": "packages/policy-engine"
  },
  "bugs": {
    "url": "https://github.com/Vinaystwt/xMPP/issues"
  },
  "keywords": ["xmpp", "policy", "stellar", "agents", "budgets", "treasury"],
  "exports": {
    ".": {
      "types": "./dist/policy-engine/src/index.d.ts",
      "import": "./dist/policy-engine/src/index.js",
      "default": "./dist/policy-engine/src/index.js"
    }
  },
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "dev": "tsc -p tsconfig.json --watch",
    "lint": "eslint src",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "test": "vitest run --passWithNoTests"
  },
  "dependencies": {
    "@xmpp/contract-runtime": "workspace:*",
    "@xmpp/types": "workspace:*"
  }
}
