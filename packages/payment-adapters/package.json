{
  "name": "@xmpp/payment-adapters",
  "version": "0.1.1",
  "description": "Advanced payment adapter package for x402, MPP charge, and MPP session execution on Stellar.",
  "type": "module",
  "license": "MIT",
  "main": "dist/payment-adapters/src/index.js",
  "types": "dist/payment-adapters/src/index.d.ts",
  "files": ["dist", "README.md", "LICENSE"],
  "sideEffects": false,
  "homepage": "https://github.com/Vinaystwt/xMPP#readme",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Vinaystwt/xMPP.git",
    "directory": "packages/payment-adapters"
  },
  "bugs": {
    "url": "https://github.com/Vinaystwt/xMPP/issues"
  },
  "keywords": ["xmpp", "stellar", "x402", "mpp", "payments", "adapters", "sessions"],
  "exports": {
    ".": {
      "types": "./dist/payment-adapters/src/index.d.ts",
      "import": "./dist/payment-adapters/src/index.js",
      "default": "./dist/payment-adapters/src/index.js"
    }
  },
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "dev": "tsc -p tsconfig.json --watch",
    "lint": "eslint src",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "test": "vitest run src --passWithNoTests"
  },
  "dependencies": {
    "@stellar/mpp": "^0.3.0",
    "@stellar/stellar-sdk": "^14.6.1",
    "@x402/core": "^2.8.0",
    "@x402/fetch": "^2.8.0",
    "@x402/stellar": "^2.8.0",
    "@xmpp/config": "workspace:*",
    "@xmpp/types": "workspace:*",
    "@xmpp/wallet": "workspace:*",
    "mppx": "^0.4.11"
  }
}
